# ── Webhook Agent .env ──────────────────────────────────────────────────────
# Copy this file to .env and fill in the values

# Port this webhook listener will run on (pick any free port, e.g. 3001, 3002)
PORT=3000

# Token from CRM UI → VPS Servers → Add VPS → copy the token shown once
VPS_TOKEN=PASTE_YOUR_VPS_TOKEN_HERE

# URL of your backend CRM API (where UI + backend are hosted)
BACKEND_API_URL=https://api.webhook.aashita.ai

# Same 64-char hex key as your backend .env ENCRYPTION_KEY
ENCRYPTION_KEY=PASTE_SAME_KEY_AS_BACKEND
